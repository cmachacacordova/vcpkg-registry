{
  "name": "i18n-redis",
  "version": "1.2.1-SNAPSHOT",
  "description": "A C++20 library for internationalization using Redis as backend",
  "dependencies": [
    "fmt",
    {
      "name": "redis-plus-plus",
      "features": [
        "async",
        "cxx17"
      ]
    },
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "default-features": [
    "simdjson"
  ],
  "features": {
    "simdjson": {
      "description": "Use simdjson for JSON parsing",
      "dependencies": [
        {
          "name": "simdjson",
          "features": [
            "exceptions",
            "threads",
            "utf8-validation"
          ]
        }
      ]
    },
    "yyjson": {
      "description": "Use yyjson for JSON parsing",
      "dependencies": [
        {
          "name": "yyjson",
          "features": [
            "reader",
            "writer"
          ]
        }
      ]
    }
  }
}
